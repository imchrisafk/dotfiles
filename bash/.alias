# Custom aliases
alias rmexif="exiftool -all= "
alias rm="gio trash"
alias ls="eza -lah"
alias cat="bat"
alias cd="z"
alias vi="nvim"
alias vim="nvim"
alias htop="btop"
alias map="telnet mapscii.me"
alias pubip="curl https://ifconfig.me"
alias weather-detroit="curl https://wttr.in/detroit_michigan?u"
alias weather-ann-arbor="curl https://wttr.in/ann-arbor?u"
alias getvid="yt-dlp -f bestvideo+bestaudio/bestvideo/best/bestaudio --embed-thumbnail --embed-metadata"
